# ─── Archon Platform — Root Environment Example ───────────────────────────────
# This file documents all environment variables used across the monorepo.
# The actual secrets live in backend/.env (see backend/.env.example).
#
# For local development:
#   cp .env.example .env                     (optional root-level)
#   cp backend/.env.example backend/.env     (required)
#   cp frontend/.env.example frontend/.env   (optional — only if cross-origin)

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database (AWS RDS PostgreSQL) ─────────────────────────────────────────────
# URL-encode special chars: ! → %21  @ → %40  # → %23
# Add sslmode=require for RDS
DATABASE_URL="postgresql://USER:PASSWORD@your-rds.rds.amazonaws.com:5432/postgres?schema=public&connection_limit=10&pool_timeout=20&sslmode=require"

# ── AI: OpenRouter (primary) ──────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_APP_NAME=Archon
OPENROUTER_SITE_URL=https://your-domain.com

# ── AI: Groq (fallback, comma-separated for key rotation) ─────────────────────
GROQ_API_KEYS=gsk_your-key-here

# ── AWS ───────────────────────────────────────────────────────────────────────
# On EC2 with IAM role: omit AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY
AWS_REGION=ap-southeast-2
AWS_S3_BUCKET=archon-artifacts
# AWS_ACCESS_KEY_ID=      # local dev only
# AWS_SECRET_ACCESS_KEY=  # local dev only

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET=replace-with-strong-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://your-domain.com
FRONTEND_URL=https://your-domain.com

# ── Feature Flags ─────────────────────────────────────────────────────────────
STORAGE_DRIVER=s3
GUEST_MODE=true

# ── Redis (optional) ──────────────────────────────────────────────────────────
# REDIS_URL=redis://127.0.0.1:6379
