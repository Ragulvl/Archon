# ─── Archon Platform — Environment Configuration ──────────────────────────────
# Copy this to .env and fill in your values

# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database (PostgreSQL / AWS RDS) ───────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@your-rds.rds.amazonaws.com:5432/archon?schema=public"

# ── AI: OpenRouter (primary) ──────────────────────────────────────
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_APP_NAME=Archon
OPENROUTER_SITE_URL=https://archon.dinez.in

# ── AI: Groq (fallback) ───────────────────────────────────────────
# Get key: https://console.groq.com/keys
GROQ_API_KEYS=gsk_your-groq-key

# ── AWS S3 ────────────────────────────────────────────────────────
# On EC2: uses IAM instance profile (no keys needed)
# For local dev: provide explicit keys
AWS_REGION=ap-south-1
AWS_S3_BUCKET=archon-artifacts
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Auth (JWT) ────────────────────────────────────────────────────
JWT_SECRET=generate-with-openssl-rand-base64-32
JWT_EXPIRES_IN=7d

# ── Feature Flags ─────────────────────────────────────────────────
STORAGE_DRIVER=local        # local | s3
GUEST_MODE=true             # true = no login required

# ── CORS ──────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
