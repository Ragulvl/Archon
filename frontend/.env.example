# ─── Archon Frontend — Environment Variables ──────────────────────────────────
# Copy to frontend/.env and fill in values.
# Never commit frontend/.env to git.
#
# ⚠️  Vite bakes these variables into the JS bundle at BUILD TIME.
#     You MUST set these BEFORE running `npm run build`.
#     Changes after build have no effect.
#
# All variables MUST be prefixed with VITE_ to be accessible in the browser.
# ─────────────────────────────────────────────────────────────────────────────

# ── API Base URL ──────────────────────────────────────────────────────────────
# Leave blank (or omit entirely) when frontend and backend share the same domain
# behind Nginx — the client will use relative /api/v1 paths automatically.
#
# Only set this if your frontend and backend are on DIFFERENT domains:
#   VITE_API_URL=https://api.your-domain.com/api/v1
VITE_API_URL=

# ── Socket.IO URL ─────────────────────────────────────────────────────────────
# Leave blank (or omit entirely) for same-origin WebSocket (standard Nginx setup).
# The socket client will connect to the current page origin via /socket.io.
#
# Only set this if backend is on a different domain:
#   VITE_SOCKET_URL=https://api.your-domain.com
VITE_SOCKET_URL=
