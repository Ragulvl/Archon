# ─── Archon Backend — Environment Configuration ───────────────────────────────
# Copy to backend/.env and fill in all required values.
# Never commit backend/.env to git.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database (AWS RDS PostgreSQL) ─────────────────────────────────────────────
# URL-encode special characters in the password (e.g. ! → %21, @ → %40)
DATABASE_URL="postgresql://USER:PASSWORD@your-rds-endpoint.rds.amazonaws.com:5432/postgres?schema=public&connection_limit=10&pool_timeout=20&sslmode=require"

# ── AI: OpenRouter (primary) ──────────────────────────────────────────────────
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_APP_NAME=Archon
OPENROUTER_SITE_URL=https://your-domain.com

# ── AI: Groq (fallback) ───────────────────────────────────────────────────────
# Multiple keys supported — comma-separated for key rotation
# Get key at: https://console.groq.com/keys
GROQ_API_KEYS=gsk_your-groq-key-here

# ── AWS (S3 artifact storage) ─────────────────────────────────────────────────
# On EC2 with IAM instance profile: leave AWS_ACCESS_KEY_ID and
# AWS_SECRET_ACCESS_KEY blank — credentials are resolved automatically.
# For local dev: provide explicit keys.
AWS_REGION=ap-southeast-2
AWS_S3_BUCKET=archon-artifacts
# AWS_ACCESS_KEY_ID=          # Local dev only
# AWS_SECRET_ACCESS_KEY=      # Local dev only

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
# REQUIRED to be >= 32 characters in production
JWT_SECRET=replace-with-output-of-openssl-rand-base64-32
JWT_EXPIRES_IN=7d

# ── CORS — comma-separated list of allowed origins ────────────────────────────
# In production, set to your exact frontend domain (no trailing slash)
CORS_ORIGIN=https://your-domain.com

# Explicit public frontend URL (used for email links, redirects, etc.)
FRONTEND_URL=https://your-domain.com

# ── Feature Flags ─────────────────────────────────────────────────────────────
# STORAGE_DRIVER: "local" (filesystem) or "s3" (AWS S3)
STORAGE_DRIVER=s3
# GUEST_MODE: "true" = no login required (open access), "false" = JWT required
GUEST_MODE=true

# ── Redis (optional — for future session store / job queue) ───────────────────
# REDIS_URL=redis://127.0.0.1:6379
